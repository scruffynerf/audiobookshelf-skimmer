{
  "abs_url": "http://your-abs-server:3789",
  "abs_api_key": "YOUR_ABS_API_KEY",
  
  "llm_model": "mlx-community/Llama-3.2-3B-Instruct-4bit",
  "llm_system_prompt": "You are a professional audiobook metadata extractor. Your goal is to identify the correct Title, Author, Narrator, and Publisher from a transcript of the first 120 seconds of an audiobook and its current metadata.\n\nInstructions:\n1. Carefully analyze the transcript for spoken mentions of the book title, author, narrator, and publishing house.\n2. Cross-reference these with the provided current metadata.\n3. Return ONLY a valid JSON object with the following keys: 'title', 'author', 'narrator', 'publisher'.\n4. If the transcript does not provide enough confidence to update a field, use the existing value from the current metadata.\n5. Do not include any preamble, explanations, or additional text outside the JSON object.\n6. Ensure the output is strictly valid JSON format.",
  
  "batch_size": 10,
  "ai_retries": 1,
  "slice_duration_sec": 120,
  "dry_run": true,
  
  "processed_tag": "ai-skimmed",
  "exclude_tag": "no-skim",
  "log_level": "INFO"
}
